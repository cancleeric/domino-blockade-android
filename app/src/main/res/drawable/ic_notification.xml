<!--
  Notification small icon for Domino Blockade.
  Must be monochrome (white on transparent) and 24×24 dp.
  Depicts a single domino tile with a dividing line.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24"
    android:tint="?attr/colorControlNormal">
    <!-- Domino tile outline -->
    <path
        android:fillColor="@android:color/white"
        android:pathData="M4,2 L4,22 Q4,22.8 4.8,22.8 L19.2,22.8 Q20,22.8 20,22 L20,2 Q20,1.2 19.2,1.2 L4.8,1.2 Q4,1.2 4,2 Z" />
    <!-- Dividing line (dark, cut-out effect via transparent stroke) -->
    <path
        android:strokeColor="#00000000"
        android:strokeWidth="1"
        android:fillColor="#AA999999"
        android:pathData="M4,12.5 L20,12.5 L20,11.5 L4,11.5 Z" />
    <!-- Upper pip (left) -->
    <path
        android:fillColor="#1C2B3A"
        android:pathData="M8.5,7 m-1.5,0 a1.5,1.5 0 1,0 3,0 a1.5,1.5 0 1,0 -3,0 Z" />
    <!-- Upper pip (right) -->
    <path
        android:fillColor="#1C2B3A"
        android:pathData="M15.5,7 m-1.5,0 a1.5,1.5 0 1,0 3,0 a1.5,1.5 0 1,0 -3,0 Z" />
    <!-- Lower pip (centre) -->
    <path
        android:fillColor="#1C2B3A"
        android:pathData="M12,17 m-1.5,0 a1.5,1.5 0 1,0 3,0 a1.5,1.5 0 1,0 -3,0 Z" />
</vector>
