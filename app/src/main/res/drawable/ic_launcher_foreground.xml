<!--
  Adaptive icon foreground for Domino Blockade.
  Depicts two domino tiles (a [3|2] arrangement) in ivory/white on a transparent
  background. The canvas is 108×108 dp; the safe zone is the central 72×72 dp region.
  Dots represent the pips on each domino half.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Left domino tile (slightly rotated for visual interest) -->
    <group
        android:pivotX="54"
        android:pivotY="54"
        android:rotation="-15">
        <!-- Tile body -->
        <path
            android:fillColor="#F5F0E8"
            android:pathData="M29,33 L29,75 Q29,78 32,78 L52,78 Q55,78 55,75 L55,33 Q55,30 52,30 L32,30 Q29,30 29,33 Z" />
        <!-- Dividing line -->
        <path
            android:fillColor="#CCBBAA"
            android:strokeColor="#CCBBAA"
            android:strokeWidth="1.5"
            android:pathData="M29,54 L55,54" />
        <!-- Upper half: 3 pips -->
        <path
            android:fillColor="#1C2B3A"
            android:pathData="M36,38 m-3,0 a3,3 0 1,0 6,0 a3,3 0 1,0 -6,0 Z" />
        <path
            android:fillColor="#1C2B3A"
            android:pathData="M42,43 m-3,0 a3,3 0 1,0 6,0 a3,3 0 1,0 -6,0 Z" />
        <path
            android:fillColor="#1C2B3A"
            android:pathData="M48,38 m-3,0 a3,3 0 1,0 6,0 a3,3 0 1,0 -6,0 Z" />
        <!-- Lower half: 2 pips -->
        <path
            android:fillColor="#1C2B3A"
            android:pathData="M36,62 m-3,0 a3,3 0 1,0 6,0 a3,3 0 1,0 -6,0 Z" />
        <path
            android:fillColor="#1C2B3A"
            android:pathData="M48,68 m-3,0 a3,3 0 1,0 6,0 a3,3 0 1,0 -6,0 Z" />
    </group>

    <!-- Right domino tile (perpendicular / rotated 90°) -->
    <group
        android:pivotX="54"
        android:pivotY="54"
        android:rotation="20">
        <!-- Tile body -->
        <path
            android:fillColor="#F5F0E8"
            android:pathData="M57,36 L57,78 Q57,81 60,81 L80,81 Q83,81 83,78 L83,36 Q83,33 80,33 L60,33 Q57,33 57,36 Z" />
        <!-- Dividing line -->
        <path
            android:fillColor="#CCBBAA"
            android:strokeColor="#CCBBAA"
            android:strokeWidth="1.5"
            android:pathData="M57,57 L83,57" />
        <!-- Upper half: 1 pip -->
        <path
            android:fillColor="#1C2B3A"
            android:pathData="M70,45 m-3,0 a3,3 0 1,0 6,0 a3,3 0 1,0 -6,0 Z" />
        <!-- Lower half: 4 pips -->
        <path
            android:fillColor="#1C2B3A"
            android:pathData="M63,63 m-3,0 a3,3 0 1,0 6,0 a3,3 0 1,0 -6,0 Z" />
        <path
            android:fillColor="#1C2B3A"
            android:pathData="M77,63 m-3,0 a3,3 0 1,0 6,0 a3,3 0 1,0 -6,0 Z" />
        <path
            android:fillColor="#1C2B3A"
            android:pathData="M63,73 m-3,0 a3,3 0 1,0 6,0 a3,3 0 1,0 -6,0 Z" />
        <path
            android:fillColor="#1C2B3A"
            android:pathData="M77,73 m-3,0 a3,3 0 1,0 6,0 a3,3 0 1,0 -6,0 Z" />
    </group>
</vector>
